{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "jsonls": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "taplo": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"]
    }
  },
  "command": {
    "commit": {
      "description": "Create a git commit following project conventions",
      "template": "Load the commit skill and follow its instructions. Group changes by top-level component. Create one commit per component unless tightly coupled.",
      "subtask": true
    },
    "stow-deploy": {
      "description": "Deploy, list, or preview stow packages",
      "template": "Load the stow-deploy skill and follow its instructions. If an argument is given, use it as the package name or action (list/preview).",
      "subtask": true
    },
    "handoff": {
      "description": "Write or archive handoff documents for interrupted work",
      "template": "Load the handoff skill. If writing, document current session's discoveries, decisions, and remaining work. If archiving, summarize and archive existing handoffs.",
      "subtask": true
    },
    "initiate": {
      "description": "Start a build-verify-retrospect loop for a handoff",
      "template": "Read the initiate skill and orchestrate the full build-verify-retrospect workflow. List handoffs, get user approval, create a feature branch, loop build/verify, run retrospect."
    },
    "build": {
      "description": "Implement a handoff's deliverables",
      "template": "Load the build skill and follow its instructions to implement the specified handoff.",
      "subtask": true
    },
    "verify": {
      "description": "Verify a handoff's implementation",
      "template": "Load the verify skill and follow its instructions to check the specified handoff's verification items.",
      "subtask": true
    },
    "retrospect": {
      "description": "Analyze a completed handoff and improve skills",
      "template": "Load the retrospect skill and follow its instructions to gather feedback and update skills.",
      "subtask": true
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.5:9b-q4_K_M": {
          "name": "Qwen 3.5 9B Q4"
        },
        "qwen3:4b-instruct": {
          "name": "Qwen 3 4B Instruct"
        }
      }
    }
  }
}
