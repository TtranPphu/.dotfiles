#!/usr/bin/env bash

set -euo pipefail

plugin_dir="${HOME}/.tmux/plugins"
tpm_dir="${plugin_dir}/tpm"

if [[ ! -d "$tpm_dir" ]]; then
  mkdir -p "$plugin_dir"

  if ! git clone --depth=1 https://github.com/tmux-plugins/tpm "$tpm_dir"; then
    tmux display-message "Failed to install TPM"
    exit 0
  fi
fi

if [[ ! -d "${plugin_dir}/tmux-resurrect" || ! -d "${plugin_dir}/tmux-continuum" ]]; then
  if ! "${tpm_dir}/bin/install_plugins"; then
    tmux display-message "Failed to install tmux plugins"
    exit 0
  fi
fi

exec "${tpm_dir}/tpm"
