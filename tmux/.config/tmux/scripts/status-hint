#!/usr/bin/env bash

line="$1"
pane_mode="$2"

copy_line_1='#[fg=blue]h/j/k/l#[fg=brightblack]: move       #[fg=blue]Space/v#[fg=brightblack]: select  #[fg=blue]Esc#[fg=brightblack]: clear   #[fg=blue]q#[fg=brightblack]: quit'
copy_line_2='#[fg=blue]C-u/C-d#[fg=brightblack]: half page  #[fg=blue]Enter/y#[fg=brightblack]: copy    #[fg=blue]/ ?#[fg=brightblack]: search'
tree_line_1='#[fg=blue]Up/Down#[fg=brightblack]: move   #[fg=blue]Enter#[fg=brightblack]: choose  #[fg=blue]+/-#[fg=brightblack]: expand/collapse  #[fg=blue]v#[fg=brightblack]: preview            #[fg=blue]q#[fg=brightblack]: quit'
tree_line_2='#[fg=blue]t/T#[fg=brightblack]: tag/clear  #[fg=blue]C-t#[fg=brightblack]: tag all   #[fg=blue]x/X#[fg=brightblack]: kill one/tagged  #[fg=blue]C-s/n#[fg=brightblack]: search/repeat'
prefix_line_1='#[fg=blue]h#[fg=brightblack]:   #[fg=blue]x#[fg=brightblack]: kill   #[fg=blue]c#[fg=brightblack]: new   #[fg=blue]r#[fg=brightblack]: rename   #[fg=blue]k#[fg=brightblack]: kill   #[fg=blue]n/p#[fg=brightblack]: next/prev   #[fg=blue]w#[fg=brightblack]: tree  #[fg=blue]d#[fg=brightblack]: detach'
prefix_line_2='#[fg=blue]v#[fg=brightblack]:   #[fg=blue]z#[fg=brightblack]: zoom   #[fg=blue]C#[fg=brightblack]: new   #[fg=blue]R#[fg=brightblack]: rename   #[fg=blue]K#[fg=brightblack]: kill   #[fg=blue]N/P#[fg=brightblack]: next/prev   #[fg=blue]e#[fg=brightblack]: copy  #[fg=blue]q#[fg=brightblack]: reload'

if [[ "$line" == 'init' ]]; then
  socket_path="$pane_mode"
  tmux -S "$socket_path" set -gq @status-hint-prefix-1 "$prefix_line_1"
  tmux -S "$socket_path" set -gq @status-hint-prefix-2 "$prefix_line_2"
  exit 0
fi

if [[ "$pane_mode" == 'copy-mode' ]]; then
  case "$line" in
    1) printf '%s' "$copy_line_1" ;;
    2) printf '%s' "$copy_line_2" ;;
  esac
  exit 0
fi

if [[ "$pane_mode" == 'tree-mode' ]]; then
  case "$line" in
    1) printf '%s' "$tree_line_1" ;;
    2) printf '%s' "$tree_line_2" ;;
  esac
  exit 0
fi
