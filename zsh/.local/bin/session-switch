#!/bin/bash
# Switch SDDM autologin session between compositors
#
# Usage:
#   session-switch          - Print current session and usage
#   session-switch niri     - Set SDDM autologin to niri
#   session-switch omarchy  - Set SDDM autologin to omarchy (Hyprland)
#   session-switch --menu   - Interactive fzf selection

set -euo pipefail

SDDM_CONF="/etc/sddm.conf.d/autologin.conf"

get_current_session() {
  if [ -f "$SDDM_CONF" ]; then
    grep -oP '(?<=^Session=).*' "$SDDM_CONF" || echo "unknown"
  else
    echo "unknown"
  fi
}

set_session() {
  local target="$1"
  local current
  current="$(get_current_session)"

  if [ "$current" = "$target" ]; then
    echo "Already set to '$target' — no change."
    return 0
  fi

  echo "Switching SDDM autologin from '$current' to '$target'..."

  # Use sudo tee to write the root-owned file, preserving the [Theme] section.
  sudo tee "$SDDM_CONF" > /dev/null <<EOF
[Autologin]
User=ttranpphu
Session=$target

[Theme]
Current=omarchy
EOF

  if [ $? -eq 0 ]; then
    echo "Done. Session will take effect after reboot."
    echo ""
    echo "  To test without rebooting:"
    echo "    - Log out, then press Escape at the SDDM countdown"
    echo "    - Select '$target' from the session menu"
  else
    echo "Error: Failed to write $SDDM_CONF" >&2
    exit 1
  fi
}

case "${1:-}" in
  niri)
    set_session "niri"
    ;;
  omarchy)
    set_session "omarchy"
    ;;
  --menu)
    selected=$(printf "omarchy\nniri" | fzf --prompt="Select session > " --height=10)
    if [ -n "$selected" ]; then
      set_session "$selected"
    else
      echo "Cancelled."
    fi
    ;;
  *)
    echo "Current session: $(get_current_session)"
    echo ""
    echo "Usage: session-switch <niri|omarchy|--menu>"
    ;;
esac
